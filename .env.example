# VAANI - Environment Configuration Example
# Copy this file to a new file named ".env" and fill in your actual values.

# Server Configuration
PORT=3000

# Database Configuration
# If using MongoDB Atlas, the URI looks like: mongodb+srv://<user>:<password>@cluster.mongodb.net/vaani
MONGO_URI=your_mongodb_connection_string_here

# Google Gemini AI Configuration
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Email Notification Configuration (Nodemailer)
# Use a 16-character Google App Password (not your regular Gmail password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_character_app_password